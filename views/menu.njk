<header class="sticky top-0 z-50 bg-white border-b border-slate-200">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 py-3 sm:py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 text-xl font-bold text-primary no-underline">
            <span><i class="fa-solid fa-building-columns"></i></span>
            <span>Consilium</span>
        </a>

        <!-- Liens desktop -->
        <div class="hidden md:flex items-center gap-6">
            <a href="/" class="text-sm text-slate-600 hover:text-slate-900">Hémicycle</a>
            <a href="/scrutins" class="text-sm text-slate-600 hover:text-slate-900">Scrutins</a>
            <a href="/partis" class="text-sm text-slate-600 hover:text-slate-900">Groupes</a>
            <div class="group relative">
                <button class="flex items-center gap-1.5 text-sm text-slate-600 hover:text-slate-900">
                    Outils
                    <svg class="h-3.5 w-3.5 transition-transform duration-150 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                    </svg>
                </button>
                <div class="absolute right-0 top-full hidden pt-1 group-hover:block">
                    <div class="w-52 rounded-xl border border-slate-200 bg-white py-1.5 shadow-lg">
                        <a href="/outils/majorite-builder" class="block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">Majorité Builder</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Burger mobile -->
        <button
            id="burger-btn"
            class="md:hidden flex flex-col justify-center items-center gap-1.5 w-8 h-8"
            aria-label="Menu"
            onclick="
                const open = document.getElementById('mobile-menu').classList.toggle('hidden');
                this.setAttribute('aria-expanded', !open);
            "
        >
            <span class="block w-5 h-0.5 bg-slate-700 transition-all duration-200"></span>
            <span class="block w-5 h-0.5 bg-slate-700 transition-all duration-200"></span>
            <span class="block w-5 h-0.5 bg-slate-700 transition-all duration-200"></span>
        </button>
    </nav>

    <!-- Menu mobile -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-slate-100">
        <div class="flex flex-col px-4 py-3 gap-0.5">
            <a href="/" class="px-3 py-2.5 text-sm text-slate-700 rounded-lg hover:bg-slate-50">Hémicycle</a>
            <a href="/scrutins" class="px-3 py-2.5 text-sm text-slate-700 rounded-lg hover:bg-slate-50">Scrutins</a>
            <a href="/partis" class="px-3 py-2.5 text-sm text-slate-700 rounded-lg hover:bg-slate-50">Groupes</a>
            <div class="mt-2 border-t border-slate-100 pt-2">
                <p class="px-3 pb-1 text-xs font-semibold uppercase tracking-wider text-slate-400">Outils</p>
                <a href="/outils/majorite-builder" class="px-3 py-2.5 text-sm text-slate-700 rounded-lg hover:bg-slate-50 block">Majorité Builder</a>
            </div>
        </div>
    </div>
</header>
