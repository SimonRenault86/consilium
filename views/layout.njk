<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{{ title }}</title>
        <link rel="stylesheet" href="/dist/main.css">
    </head>
    <body class="min-h-screen bg-slate-50">

        <header class="bg-white border-b border-slate-200">
            <nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
                <a href="/" class="flex items-center gap-2 text-xl font-bold text-primary no-underline">
                    <span>🏛</span>
                    <span>Politica</span>
                </a>
            </nav>
        </header>

        <main class="max-w-7xl mx-auto px-6 py-10">
            {% block content %}{% endblock %}
        </main>

        <footer class="border-t border-slate-200 mt-12 px-6 py-6 text-center text-sm text-slate-400">
            Données ouvertes — <a href="https://data.assemblee-nationale.fr" class="underline">Assemblée Nationale</a>
        </footer>

        <script type="module" src="/dist/main.js"></script>
    </body>
</html>
