{% extends "layout.njk" %}

{% block content %}
    <div class="mb-5 sm:mb-6">
        <h1 class="text-2xl sm:text-3xl font-bold text-slate-900">Groupes politiques</h1>
        <p class="text-slate-400 text-sm mt-1">{{ totalDeputes }} député{{ 's' if totalDeputes > 1 }} répartis en {{ groupes.length }} groupe{{ 's' if groupes.length > 1 }}</p>
    </div>

    {% for groupe in groupes %}
    <section class="mb-4" id="{{ groupe.abrev }}">
        <a href="/partis/{{ groupe.abrev }}" class="flex items-center gap-3 bg-white rounded-xl border border-slate-200 px-4 py-3 hover:border-slate-300 hover:shadow-sm transition no-underline hover:no-underline">
            {% if groupe.logo %}
                <img src="{{ groupe.logo }}" alt="{{ groupe.nom }}" class="h-7 object-contain">
            {% else %}
                <span class="text-xs font-bold px-2 py-1 rounded bg-slate-100 text-slate-600">{{ groupe.abrev }}</span>
            {% endif %}
            <div class="flex-1 min-w-0">
                <h2 class="text-base font-bold text-slate-900 truncate">{{ groupe.nom }}</h2>
            </div>
            <span class="text-sm text-slate-400 shrink-0">{{ groupe.deputes.length }} député{{ 's' if groupe.deputes.length > 1 }}</span>
        </a>
    </section>
    {% endfor %}
{% endblock %}
