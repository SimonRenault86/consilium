{% extends "layout.njk" %}

{% block head %}
{% if schemaJson %}<script type="application/ld+json">{{ schemaJson | safe }}</script>{% endif %}
{% endblock %}

{% block content %}
    <div class="mb-6">
        <a href="/" class="text-sm text-primary-500 hover:text-primary-700">← Retour à l'hémicycle</a>
    </div>

    {% if not vote %}
        <section class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
            <p class="text-primary-500">Scrutin introuvable.</p>
        </section>
    {% else %}

    {# En-tête SSR (pour SEO) #}
    <section class="bg-white rounded-2xl shadow-sm border border-slate-200 p-5 sm:p-8 mb-6">
        <div class="flex items-center gap-3 mb-1">
            <span class="inline-flex items-center justify-center rounded-full px-3 py-1 text-sm font-bold uppercase
                {% if vote.sort === 'adopté' %}bg-emerald-100 text-emerald-700{% else %}bg-red-100 text-red-700{% endif %}">
                {{ vote.sort | capitalize }}
            </span>
            <span class="text-xs text-primary-500">Scrutin n°{{ vote.numero }}{% if vote.dateFormatee %} · {{ vote.dateFormatee }}{% endif %}</span>
        </div>
        <h1 class="text-xl sm:text-2xl font-bold text-primary-900 mt-2">
            {{ vote.titre or ("Scrutin n°" + vote.numero) }}
        </h1>
    </section>

    <scrutin-info data-scrutin-uid="{{ vote.uid }}" class="mb-6 block"></scrutin-info>

    {% endif %}
{% endblock %}
