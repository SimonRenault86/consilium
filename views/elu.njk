{% extends "layout.njk" %}

{% block content %}
    <div class="mb-6">
        <a href="/" class="text-sm text-primary-500 hover:text-primary-700">← Retour à l'hémicycle</a>
    </div>

    {% if not depute %}
        <section class="bg-white rounded-sm shadow-sm border border-slate-200 p-8">
            <p class="text-primary-500">Député introuvable.</p>
        </section>
    {% else %}

    {# En-tête #}
    <section class="bg-white rounded-sm shadow-sm border border-slate-200 p-5 sm:p-8 mb-6">
        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-4 sm:gap-6 text-center sm:text-left">
            <div class="flex-shrink-0 relative w-20 h-20 sm:w-24 sm:h-24">
                <img
                    src="/elus/{{ depute.id }}.jpg"
                    alt="Photo de {{ depute.prenom }} {{ depute.nom }}"
                    class="w-20 h-20 sm:w-24 sm:h-24 rounded-full object-cover border border-slate-100"
                    onerror="this.style.display='none'; document.getElementById('initiales').style.display='flex'"
                >
                <div
                    id="initiales"
                    class="w-20 h-20 sm:w-24 sm:h-24 rounded-full bg-slate-200 text-primary-600 text-2xl font-bold absolute inset-0 hidden items-center justify-center"
                >
                    {{ depute.prenom[0] }}{{ depute.nom[0] }}
                </div>
            </div>
            <div>
                <h1 class="text-2xl sm:text-3xl font-bold text-primary-900">{{ depute.civ }} {{ depute.prenom }} {{ depute.nom }}</h1>
                {% if groupe %}
                <div class="flex items-center gap-2 mt-2">
                    {% if groupe.logo %}
                        <img src="{{ groupe.logo }}" alt="{{ groupe.nom }}" class="h-5 object-contain">
                    {% else %}
                        <span class="text-xs font-bold px-1.5 py-0.5 rounded bg-primary-100 text-primary-600">{{ depute.groupeAbrev }}</span>
                    {% endif %}
                    <span class="text-primary-600 text-sm">{{ groupe.nom }}</span>
                </div>
                {% endif %}
            </div>
        </div>
    </section>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">

        {# Mandat #}
        <section class="bg-white rounded-sm shadow-sm border border-slate-200 p-4 sm:p-6">
            <h2 class="text-xs font-semibold text-primary-500 uppercase tracking-widest mb-4">Mandat</h2>
            <dl class="space-y-3">
                <div>
                    <dt class="text-xs text-primary-500 mb-0.5">Circonscription</dt>
                    <dd class="text-primary-700 font-medium">
                        {{ depute.departementNom }}{% if depute.departementCode %} ({{ depute.departementCode }}){% endif %} — {{ depute.circo }}e
                    </dd>
                </div>
                {% if mandatPrincipal and mandatPrincipal.region %}
                <div>
                    <dt class="text-xs text-primary-500 mb-0.5">Région</dt>
                    <dd class="text-primary-700 font-medium">{{ mandatPrincipal.region }}</dd>
                </div>
                {% endif %}
                {% if mandatPrincipal and mandatPrincipal.legislature %}
                <div>
                    <dt class="text-xs text-primary-500 mb-0.5">Législature</dt>
                    <dd class="text-primary-700 font-medium">{{ mandatPrincipal.legislature }}e</dd>
                </div>
                {% endif %}
                {% if depute.priseFonctionFormatee %}
                <div>
                    <dt class="text-xs text-primary-500 mb-0.5">Prise de fonction</dt>
                    <dd class="text-primary-700 font-medium">{{ depute.priseFonctionFormatee }}</dd>
                </div>
                {% endif %}
                {% if mandatPrincipal and mandatPrincipal.causeMandat %}
                <div>
                    <dt class="text-xs text-primary-500 mb-0.5">Cause du mandat</dt>
                    <dd class="text-primary-700 font-medium capitalize">{{ mandatPrincipal.causeMandat }}</dd>
                </div>
                {% endif %}
                {% if mandatPrincipal and mandatPrincipal.placeHemicycle %}
                <div>
                    <dt class="text-xs text-primary-500 mb-0.5">Siège à l'hémicycle</dt>
                    <dd class="text-primary-700 font-medium">N° {{ mandatPrincipal.placeHemicycle }}</dd>
                </div>
                {% endif %}
                {% if depute.nombreMandats %}
                <div>
                    <dt class="text-xs text-primary-500 mb-0.5">Expérience</dt>
                    <dd class="text-primary-700 font-medium">
                        {{ depute.nombreMandats }} mandat{% if depute.nombreMandats > 1 %}s{% endif %}{% if depute.experienceDepute %} · {{ depute.experienceDepute }}{% endif %}
                        {% if mandatPrincipal and mandatPrincipal.premiereElection %} · <span class="text-emerald-600">Première élection</span>{% endif %}
                    </dd>
                </div>
                {% endif %}
            </dl>
        </section>

        {# Identité #}
        <section class="bg-white rounded-sm shadow-sm border border-slate-200 p-4 sm:p-6">
            <h2 class="text-xs font-semibold text-primary-500 uppercase tracking-widest mb-4">Identité</h2>
            <dl class="space-y-3">
                {% if depute.naissanceFormatee %}
                <div>
                    <dt class="text-xs text-primary-500 mb-0.5">Date de naissance</dt>
                    <dd class="text-primary-700 font-medium">
                        {{ depute.naissanceFormatee }}{% if depute.age %} ({{ depute.age }} ans){% endif %}
                    </dd>
                </div>
                {% endif %}
                {% if depute.villeNaissance %}
                <div>
                    <dt class="text-xs text-primary-500 mb-0.5">Lieu de naissance</dt>
                    <dd class="text-primary-700 font-medium">{{ depute.villeNaissance }}</dd>
                </div>
                {% endif %}
                {% if depute.job %}
                <div>
                    <dt class="text-xs text-primary-500 mb-0.5">Profession</dt>
                    <dd class="text-primary-700 font-medium">{{ depute.job }}</dd>
                </div>
                {% endif %}
            </dl>
        </section>

    </div>

    {# Commissions & collaborateurs #}
    {% if commissions.length or (mandatPrincipal and mandatPrincipal.collaborateurs.length) %}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">

        {% if commissions.length %}
        <section class="bg-white rounded-sm shadow-sm border border-slate-200 p-4 sm:p-6">
            <h2 class="text-xs font-semibold text-primary-500 uppercase tracking-widest mb-4">Commission{% if commissions.length > 1 %}s{% endif %} permanente{% if commissions.length > 1 %}s{% endif %}</h2>
            <ul class="space-y-2">
                {% for commission in commissions %}
                <li class="flex items-start gap-2">
                    <span class="mt-1 flex-shrink-0 w-1.5 h-1.5 rounded-full bg-blue-400"></span>
                    <span class="text-primary-700 text-sm">
                        {{ commission.nom }}
                        {% if commission.role and commission.role != 'Membre' %}
                        <span class="ml-1 text-xs text-primary-500">({{ commission.role }})</span>
                        {% endif %}
                    </span>
                </li>
                {% endfor %}
            </ul>
        </section>
        {% endif %}

        {% if mandatPrincipal and mandatPrincipal.collaborateurs.length %}
        <section class="bg-white rounded-sm shadow-sm border border-slate-200 p-4 sm:p-6">
            <h2 class="text-xs font-semibold text-primary-500 uppercase tracking-widest mb-4">Collaborateurs parlementaires</h2>
            <ul class="space-y-2">
                {% for collaborateur in mandatPrincipal.collaborateurs %}
                <li class="flex items-center gap-2 text-sm text-primary-700">
                    <span class="flex-shrink-0 w-1.5 h-1.5 rounded-full bg-slate-300"></span>
                    {{ collaborateur }}
                </li>
                {% endfor %}
            </ul>
        </section>
        {% endif %}

    </div>
    {% endif %}

    {# Activité parlementaire #}
    <section class="bg-white rounded-sm shadow-sm border border-slate-200 p-4 sm:p-6 mb-6">
        <h2 class="text-xs font-semibold text-primary-500 uppercase tracking-widest mb-4">Activité parlementaire</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {% if depute.scoreParticipationPct is not none %}
            <div>
                <div class="flex justify-between items-center mb-1.5">
                    <span class="text-sm text-primary-600">Participation</span>
                    <span class="text-sm font-semibold text-primary-700">{{ depute.scoreParticipationPct }} %</span>
                </div>
                <div class="h-2 bg-primary-100 rounded-full overflow-hidden">
                    <div class="h-2 rounded-full bg-blue-500" style="width: {{ depute.scoreParticipationPct }}%"></div>
                </div>
            </div>
            {% endif %}
            {% if depute.scoreLoyautePct is not none %}
            <div>
                <div class="flex justify-between items-center mb-1.5">
                    <span class="text-sm text-primary-600">Loyauté au groupe</span>
                    <span class="text-sm font-semibold text-primary-700">{{ depute.scoreLoyautePct }} %</span>
                </div>
                <div class="h-2 bg-primary-100 rounded-full overflow-hidden">
                    <div class="h-2 rounded-full bg-emerald-500" style="width: {{ depute.scoreLoyautePct }}%"></div>
                </div>
            </div>
            {% endif %}
        </div>
    </section>

    {# Récapitulatif des votes #}
    {% if votesStats %}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">

        <section class="bg-white rounded-sm shadow-sm border border-slate-200 p-4 sm:p-6">
            <h2 class="text-xs font-semibold text-primary-500 uppercase tracking-widest mb-4">Votes au scrutin public</h2>
            <p class="text-3xl font-bold text-primary-900 mb-4">{{ votesStats.total }}</p>
            <div class="space-y-3">
                <div>
                    <div class="flex justify-between items-center mb-1">
                        <span class="text-sm text-primary-600 flex items-center gap-1.5">
                            <span class="inline-block w-2.5 h-2.5 rounded-full bg-emerald-500"></span>Pour
                        </span>
                        <span class="text-sm font-semibold text-primary-700">{{ votesStats.pour }}</span>
                    </div>
                    <div class="h-1.5 bg-primary-100 rounded-full overflow-hidden">
                        <div class="h-full bg-emerald-500 rounded-full" style="width: {{ (votesStats.pour / votesStats.total * 100) | round }}%"></div>
                    </div>
                </div>
                <div>
                    <div class="flex justify-between items-center mb-1">
                        <span class="text-sm text-primary-600 flex items-center gap-1.5">
                            <span class="inline-block w-2.5 h-2.5 rounded-full bg-red-500"></span>Contre
                        </span>
                        <span class="text-sm font-semibold text-primary-700">{{ votesStats.contre }}</span>
                    </div>
                    <div class="h-1.5 bg-primary-100 rounded-full overflow-hidden">
                        <div class="h-full bg-red-500 rounded-full" style="width: {{ (votesStats.contre / votesStats.total * 100) | round }}%"></div>
                    </div>
                </div>
                <div>
                    <div class="flex justify-between items-center mb-1">
                        <span class="text-sm text-primary-600 flex items-center gap-1.5">
                            <span class="inline-block w-2.5 h-2.5 rounded-full bg-slate-300"></span>Abstentions
                        </span>
                        <span class="text-sm font-semibold text-primary-700">{{ votesStats.abstentions }}</span>
                    </div>
                    <div class="h-1.5 bg-primary-100 rounded-full overflow-hidden">
                        <div class="h-full bg-slate-300 rounded-full" style="width: {{ (votesStats.abstentions / votesStats.total * 100) | round }}%"></div>
                    </div>
                </div>
            </div>
        </section>

        {% if derniersVotes.length %}
        <section class="bg-white rounded-sm shadow-sm border border-slate-200 p-4 sm:p-6">
            <h2 class="text-xs font-semibold text-primary-500 uppercase tracking-widest mb-4">5 derniers scrutins</h2>
            <ul class="space-y-3">
                {% for vote in derniersVotes %}
                <li class="flex items-start gap-3">
                    <span class="mt-0.5 flex-shrink-0 inline-flex items-center justify-center rounded-full px-2 py-0.5 text-xs font-bold uppercase
                        {% if vote.position === 'pour' %}bg-emerald-100 text-emerald-700
                        {% elif vote.position === 'contre' %}bg-red-100 text-red-700
                        {% else %}bg-primary-100 text-primary-600{% endif %}">
                        {% if vote.position === 'pour' %}Pour
                        {% elif vote.position === 'contre' %}Contre
                        {% else %}Abst.{% endif %}
                    </span>
                    <div class="min-w-0">
                        <p class="text-sm text-primary-700 leading-snug line-clamp-2">{{ vote.titre }}</p>
                        <p class="text-xs text-primary-500 mt-0.5">Scrutin n°{{ vote.numero }} · {{ vote.dateScrutin }}
                            <span class="ml-1 {% if vote.sort === 'adopté' %}text-emerald-600{% else %}text-red-500{% endif %}">· {{ vote.sort }}</span>
                        </p>
                    </div>
                </li>
                {% endfor %}
            </ul>
        </section>
        {% endif %}

    </div>
    {% endif %}

    {# Contact & liens #}
    {% if depute.mail or depute.twitter or depute.facebook or depute.website or hatvpUrl %}    <section class="bg-white rounded-sm shadow-sm border border-slate-200 p-4 sm:p-6">
        <h2 class="text-xs font-semibold text-primary-500 uppercase tracking-widest mb-4">Contact & liens</h2>
        <div class="flex flex-wrap gap-3">
            {% if depute.mail %}
            <a href="mailto:{{ depute.mail }}" class="inline-flex items-center gap-1.5 text-sm text-primary-600 hover:text-primary-900 border border-slate-200 rounded-lg px-3 py-1.5">
                ✉ {{ depute.mail }}
            </a>
            {% endif %}
            {% if depute.twitter %}
            <a href="https://twitter.com/{{ depute.twitter | replace('@', '') }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm text-primary-600 hover:text-primary-900 border border-slate-200 rounded-lg px-3 py-1.5">
                𝕏 {{ depute.twitter }}
            </a>
            {% endif %}
            {% if depute.facebook %}
            <a href="https://facebook.com/{{ depute.facebook }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm text-primary-600 hover:text-primary-900 border border-slate-200 rounded-lg px-3 py-1.5">
                Facebook
            </a>
            {% endif %}
            {% if depute.website %}
            <a href="https://{{ depute.website }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm text-primary-600 hover:text-primary-900 border border-slate-200 rounded-lg px-3 py-1.5">
                🌐 Site web
            </a>
            {% endif %}
            {% if hatvpUrl %}
            <a href="{{ hatvpUrl }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm text-primary-600 hover:text-primary-900 border border-slate-200 rounded-lg px-3 py-1.5">
                📋 Déclaration HATVP
            </a>
            {% endif %}
        </div>
    </section>
    {% endif %}

    {# Députés de la même circonscription #}
    {% if deputesSimilaires.length %}
    <section class="mt-8">
        <h2 class="text-xs font-semibold text-primary-500 uppercase tracking-widest mb-4">Autres députés — {{ depute.departementNom }}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3 sm:gap-4">
            {% for similaire in deputesSimilaires %}
            <a href="/elu/{{ similaire.slug }}" class="bg-white rounded-sm shadow-sm border border-slate-200 p-3 sm:p-4 flex items-center gap-3 sm:gap-4 hover:border-slate-300 hover:shadow transition">
                <div class="relative flex-shrink-0 w-12 h-12">
                    <img
                        src="{{ similaire.photoUrl }}"
                        alt="{{ similaire.prenom }} {{ similaire.nom }}"
                        class="w-12 h-12 rounded-full object-cover border border-slate-100"
                        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
                    >
                    <div class="w-12 h-12 rounded-full bg-slate-200 text-primary-600 font-bold absolute inset-0 hidden items-center justify-center text-sm">{{ similaire.initiales }}</div>
                </div>
                <span class="font-medium text-primary-700">{{ similaire.prenom }} {{ similaire.nom }}</span>
            </a>
            {% endfor %}
        </div>
    </section>
    {% endif %}

    {% endif %}
{% endblock %}

