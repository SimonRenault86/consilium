{% extends "layout.njk" %}

{% block content %}
    <div class="mb-5 sm:mb-8">
        <h1 class="text-2xl sm:text-3xl font-extrabold text-primary-900 mb-2">Assemblée Nationale</h1>
        <p class="text-primary-600 text-sm hidden sm:block">
            Visualisez les <span class="font-extrabold text-secondary-600">577</span> sièges de l'hémicycle - Survolez un siège pour afficher le député - Cliquez pour accéder à sa fiche.
        </p>
        <p class="text-xs text-primary-500 mt-1 hidden sm:block">
            Données issues de <a href="https://data.assemblee-nationale.fr" class="underline text-secondary-500 hover:text-secondary-600" target="_blank" rel="noopener noreferrer">data.assemblee-nationale.fr</a>.
        </p>
    </div>

    <div id="assembly-map">
        <div class="flex flex-col items-center justify-center h-64 gap-2 text-primary-500">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
            </svg>
            <span class="text-sm">Chargement de la carte…</span>
        </div>
    </div>
{% endblock %}
