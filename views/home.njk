{% extends "layout.njk" %}

{% block content %}
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-slate-900 mb-2">Assemblée Nationale</h1>
        <p class="text-slate-500 text-sm">
            Visualisez les 577 sièges de l'hémicycle · Survolez un siège pour afficher le député · Cliquez pour accéder à sa fiche.
        </p>
    </div>

    <section class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div id="assembly-map">
            <div class="flex flex-col items-center justify-center h-64 gap-2 text-slate-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                </svg>
                <span class="text-sm">Chargement de la carte…</span>
            </div>
        </div>
    </section>
{% endblock %}
