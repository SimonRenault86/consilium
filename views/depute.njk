{% extends "layout.njk" %}

{% block head %}
{% if schemaJson %}<script type="application/ld+json">{{ schemaJson | safe }}</script>{% endif %}
{% endblock %}

{% block content %}
    <div class="mb-6">
        <a href="/" class="inline-flex items-center gap-1.5 font-medium transition-colors bg-secondary-600 text-white ring-1 ring-inset ring-secondary-600 hover:bg-secondary-700 hover:ring-secondary-700 px-3 py-1 text-xs rounded-sm" style="text-decoration:none">← Retour à l'hémicycle</a>
    </div>

    {% if not depute %}
        <section class="bg-white rounded-sm shadow-sm border border-slate-200 p-8">
            <p class="text-primary-500">Député introuvable.</p>
        </section>
    {% else %}

    {# En-tête #}
    <depute-header data-depute-id="{{ depute.id }}" class="block"></depute-header>

    <depute-info data-depute-id="{{ depute.id }}" class="mb-6 block"></depute-info>

    <scrutins-stats data-depute-id="{{ depute.id }}" class="mb-6 block"></scrutins-stats>

    <depute-coherence data-depute-id="{{ depute.id }}" class="block"></depute-coherence>

    {% if depute.groupeAbrev %}
    <depute-qags data-depute-id="{{ depute.id }}" class="mb-6 block"></depute-qags>
    {% endif %}

    {# Députés de la même circonscription #}
    {% if deputesSimilaires.length %}
    <section class="mt-8">
        <h2 class="text-xs font-semibold text-primary-500 uppercase tracking-widest mb-4">Autres députés — {{ depute.departementNom }}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3 sm:gap-4">
            {% for similaire in deputesSimilaires %}
            <a href="/depute/{{ similaire.slug }}" class="bg-white rounded-sm shadow-sm border border-slate-200 p-3 sm:p-4 flex items-center gap-3 sm:gap-4 hover:border-slate-300 hover:shadow transition">
                <div class="relative flex-shrink-0 w-12 h-12">
                    <img
                        src="{{ similaire.photoUrl }}"
                        alt="{{ similaire.prenom }} {{ similaire.nom }}"
                        class="w-12 h-12 rounded-full object-cover border border-slate-100"
                        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
                    >
                    <div class="w-12 h-12 rounded-full bg-slate-200 text-primary-600 font-bold absolute inset-0 hidden items-center justify-center text-sm">{{ similaire.initiales }}</div>
                </div>
                <span class="font-medium text-primary-700">{{ similaire.prenom }} {{ similaire.nom }}</span>
            </a>
            {% endfor %}
        </div>
    </section>
    {% endif %}

    {% endif %}
{% endblock %}
