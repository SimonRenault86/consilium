{% extends "layout.njk" %}

{% block content %}
    <div class="mb-6">
        <a href="/" class="text-sm text-slate-500 hover:text-slate-700">← Retour à l'hémicycle</a>
    </div>

    {% if not depute %}
        <section class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
            <p class="text-slate-500">Député introuvable.</p>
        </section>
    {% else %}

    {# En-tête #}
    <section class="bg-white rounded-2xl shadow-sm border border-slate-200 p-5 sm:p-8 mb-6">
        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-4 sm:gap-6 text-center sm:text-left">
            <div class="flex-shrink-0 relative w-20 h-20 sm:w-24 sm:h-24">
                <img
                    src="/elus/{{ depute.id }}.jpg"
                    alt="Photo de {{ depute.prenom }} {{ depute.nom }}"
                    class="w-20 h-20 sm:w-24 sm:h-24 rounded-full object-cover border border-slate-100"
                    onerror="this.style.display='none'; document.getElementById('initiales').style.display='flex'"
                >
                <div
                    id="initiales"
                    class="w-20 h-20 sm:w-24 sm:h-24 rounded-full bg-slate-200 text-slate-600 text-2xl font-bold absolute inset-0 hidden items-center justify-center"
                >
                    {{ depute.prenom[0] }}{{ depute.nom[0] }}
                </div>
            </div>
            <div>
                <h1 class="text-2xl sm:text-3xl font-bold text-slate-900">{{ depute.civ }} {{ depute.prenom }} {{ depute.nom }}</h1>
                {% if groupe %}
                <div class="flex items-center gap-2 mt-2">
                    {% if groupe.logo %}
                        <img src="{{ groupe.logo }}" alt="{{ groupe.nom }}" class="h-5 object-contain">
                    {% else %}
                        <span class="text-xs font-bold px-1.5 py-0.5 rounded bg-slate-100 text-slate-600">{{ depute.groupeAbrev }}</span>
                    {% endif %}
                    <span class="text-slate-600 text-sm">{{ groupe.nom }}</span>
                </div>
                {% endif %}
            </div>
        </div>
    </section>

    <depute-info data-depute-id="{{ depute.id }}" class="mb-6 block"></depute-info>

    <votes-stats data-depute-id="{{ depute.id }}" class="mb-6 block"></votes-stats>

    {# Députés de la même circonscription #}
    {% if deputesSimilaires.length %}
    <section class="mt-8">
        <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">Autres députés — {{ depute.departementNom }}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3 sm:gap-4">
            {% for similaire in deputesSimilaires %}
            <a href="/depute/{{ similaire.slug }}" class="bg-white rounded-2xl shadow-sm border border-slate-200 p-3 sm:p-4 flex items-center gap-3 sm:gap-4 hover:border-slate-300 hover:shadow transition">
                <div class="relative flex-shrink-0 w-12 h-12">
                    <img
                        src="{{ similaire.photoUrl }}"
                        alt="{{ similaire.prenom }} {{ similaire.nom }}"
                        class="w-12 h-12 rounded-full object-cover border border-slate-100"
                        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
                    >
                    <div class="w-12 h-12 rounded-full bg-slate-200 text-slate-600 font-bold absolute inset-0 hidden items-center justify-center text-sm">{{ similaire.initiales }}</div>
                </div>
                <span class="font-medium text-slate-800">{{ similaire.prenom }} {{ similaire.nom }}</span>
            </a>
            {% endfor %}
        </div>
    </section>
    {% endif %}

    {% endif %}
{% endblock %}
