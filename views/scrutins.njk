{% extends "layout.njk" %}

{% block content %}
    <div class="mb-6">
        <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-2">Scrutins</h1>
        <p class="text-slate-500 text-sm">Les derniers votes de l'Assemblée Nationale</p>
    </div>

    <div class="mb-6">
        <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-3">Groupes politiques</h2>
        <div class="flex flex-wrap gap-2">
            {% for groupe in groupes %}
            <a href="/partis/{{ groupe.abrev }}" class="flex items-center gap-2 bg-white border border-slate-200 rounded-xl px-3 py-2 hover:border-slate-300 hover:shadow-sm transition text-sm font-medium text-slate-700 no-underline hover:no-underline">
                {% if groupe.logo %}
                    <img src="{{ groupe.logo }}" alt="{{ groupe.nom }}" class="h-5 w-auto object-contain">
                {% else %}
                    <span class="text-xs font-bold px-1.5 py-0.5 rounded" style="background: {{ groupe.couleur }}22; color: {{ groupe.couleur }}">{{ groupe.abrev }}</span>
                {% endif %}
                <span class="hidden sm:inline">{{ groupe.nom }}</span>
                <span class="sm:hidden">{{ groupe.abrev }}</span>
            </a>
            {% endfor %}
        </div>
    </div>

    <scrutins-list class="block"></scrutins-list>
{% endblock %}
