{% extends "layout.njk" %}

{% block head %}
{% if schemaJson %}<script type="application/ld+json">{{ schemaJson | safe }}</script>{% endif %}
{% endblock %}

{% block content %}
    <div class="mb-6">
        <a href="/qags" class="text-sm text-primary-500 hover:text-primary-700">← Retour aux sessions QaG</a>
    </div>

    {% if not date %}
        <section class="bg-white rounded-sm shadow-sm border border-slate-200 p-8">
            <p class="text-primary-500">Session introuvable.</p>
        </section>
    {% else %}

    <section class="bg-white rounded-sm shadow-sm border border-slate-200 p-5 sm:p-8 mb-6">
        <div class="flex items-center gap-2 mb-1">
            <span class="inline-flex items-center justify-center rounded-full bg-secondary-100 text-secondary-700 px-3 py-1 text-sm font-bold">
                <i class="fa-solid fa-comments mr-1.5"></i> QaG
            </span>
        </div>
        <h1 class="text-xl sm:text-2xl font-bold text-primary-900 mt-2">
            Questions au Gouvernement · {{ dateFormatee }}
        </h1>
    </section>

    <qag-session data-date="{{ date }}" class="block"></qag-session>

    {% endif %}
{% endblock %}
