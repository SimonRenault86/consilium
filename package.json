        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-vue": "^5.1.0",
        "dotenv": "^17.3.1",
        "express": "^4.19.2",
        "nunjucks": "^3.2.4",
        "pg": "^8.20.0",
        "sass": "^1.75.0",
