{
    "name": "consilium",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev:back": "nodemon back/server.js",
        "dev:front": "vite build --watch",
        "dev": "concurrently \"npm run dev:back\" \"npm run dev:front\"",
        "build": "vite build",
        "heroku-postbuild": "vite build",
        "start": "node back/server.js",
        "seed:acteurs": "node back/db/seeds/acteurs.js",
        "seed:ministres": "node back/db/seeds/ministres.js",
        "seed:senateurs": "node back/db/seeds/senateurs.js",
        "seed:deputes": "node back/db/seeds/deputes.js",
        "seed:partis": "node back/db/seeds/partis.js",
        "seed:scrutins": "node back/db/seeds/votes.js",
        "seed:amendements": "node back/db/seeds/amendements.js",
        "seed:categorise-amendements": "node back/db/seeds/categorise-amendements.js",
        "seed:categorise-scrutins": "node back/db/seeds/categorise-votes.js",
        "seed:qags": "node back/db/seeds/qags.js",
        "seed:categorise-qags": "node back/db/seeds/categorise-qags.js",
        "seed:coherence": "node back/db/seeds/coherence.js",
        "seed:rapport-hebdo": "node back/db/seeds/rapport-hebdo.js",
        "photos:deputes": "node scripts/photos.js",
        "photos:ministres": "node scripts/photos.js --source=ministres",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix"
    },
    "dependencies": {
        "@fortawesome/fontawesome-free": "^7.2.0",
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-vue": "^5.1.0",
        "chart.js": "^4.5.1",
        "dayjs": "^1.11.20",
        "dotenv": "^17.3.1",
        "express": "^4.19.2",
        "express-rate-limit": "^8.3.2",
        "helmet": "^8.1.0",
        "nunjucks": "^3.2.4",
        "pg": "^8.20.0",
        "sass": "^1.75.0",
        "tailwindcss": "^4.0.0",
        "vite": "^6.0.0",
        "vue": "^3.5.0",
        "vue-chartjs": "^5.3.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.10.0",
        "concurrently": "^9.0.0",
        "eslint": "^10.1.0",
        "eslint-plugin-vue": "^10.8.0",
        "globals": "^17.4.0",
        "nodemon": "^3.1.0"
    }
}
